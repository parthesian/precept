{
  "name": "precept",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@precept/api",
    "dev:web": "turbo dev --filter=@precept/web",
    "build": "turbo build",
    "pipeline": "turbo pipeline --filter=@precept/pipeline",
    "db:migrate": "turbo db:migrate --filter=@precept/db",
    "db:reset:local": "powershell -ExecutionPolicy Bypass -File ./scripts/clear-local-db.ps1",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.5"
  }
}
